# Rust
/target
**/target/
**/*.rs.bk
*.pdb
Cargo.lock.bak

# Cargo registry / git auth (never commit)
.cargo/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Claude Code project-local config (settings, plans, agents)
.claude/

# Manager↔executor file-based bus (internal AI dev pipeline; results ship via
# normal commits to crates/, docs/, README.md, etc — not these working files)
/prompts/
/reports/
/tools/bus/

# OS
Thumbs.db

# Local config / runs
.dismantle/
.env
.env.local

# Weights and large artifacts (never commit)
weights/
checkpoints/
models/
*.safetensors
*.gguf
*.bin

# Competitor benchmark outputs / pinned versions / installs
tools/competitors/results.json
tools/competitors/versions.json
tools/competitors/build/
tools/competitors/.venv/

# Bench outputs
runs/
bench_out/
*.bench.json

# Logs
*.log

# Generated metallib (we embed shaders via include_str! at runtime,
# but local build experiments may emit these)
*.metallib
*.air

# Per-run bench output dirs (history is kept in bench_history.jsonl)
bench_results/coexist_*/
bench_results/v0.3.*/

# Python project conventions (used by eagle4/ and any future Python sub-projects)
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Numpy archive artifacts — checkpoints, frozen weights, training shards
*.npz

# eagle4/ runtime artifacts (regeneratable via eagle4/eagle4.py frozen + capture.py)
# Listed explicitly even though /eagle4/checkpoints/, /eagle4/models/ are already
# caught by the generic checkpoints/ + models/ rules above — kept here as a
# self-documenting anchor so a future cleanup pass can find them.
/eagle4/data/
/eagle4/v2lite_frozen.npz
