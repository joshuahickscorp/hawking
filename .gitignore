/prompts/
/reports/
/tools/bus/

# OS
Thumbs.db

# Local config / runs
.dismantle/
.env
.env.local

# Weights and large artifacts (never commit)
weights/
checkpoints/
models/
*.safetensors
*.gguf
*.bin

# Condense working dirs: model weights, calib corpora, measurement artifacts
# (scratch/ ~18GB of safetensors+sidecars; research/ measurement JSON).
# Reproducible from source + scripts; never commit.
scratch/
research/

# Generated specialization artifacts: calibration corpus parquet shards,
# learned-head .npz files, per-tensor quant configs, vocab-prune tables.
# Produced by tools/training/* and tools/quant/*. Multi-GB; rebuild from
# source, never commit. See dismantle-execution-plan-* / task #7.
/artifacts/

# Python virtualenvs (never commit; multi-GB with torch)
.venv/
venv/
__pycache__/

# Silicon-build kernel prototypes (~629MB; the simdgroup-MMA + int4kv sources the
# Tier-1/2 levers port from). Kept on disk for the GPU-bench lane; never committed.
silicon-builds/

# Competitor benchmark outputs / pinned versions / installs
tools/competitors/results.json
tools/competitors/versions.json
tools/competitors/build/
tools/competitors/.venv/

# Bench outputs
runs/
bench_out/
*.bench.json

# Logs
*.log

# Generated metallib (we embed shaders via include_str! at runtime,
