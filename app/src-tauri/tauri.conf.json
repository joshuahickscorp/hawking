{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HIDE",
  "version": "0.1.0",
  "identifier": "com.hawking.hide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5273",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "HIDE",
        "width": 1440,
        "height": 900,
        "minWidth": 880,
        "minHeight": 560,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8744 ws://127.0.0.1:8744; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "externalBin": ["binaries/hide-serve"],
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "Entitlements.plist"
    },
    "category": "DeveloperTool",
    "shortDescription": "Local-first agentic coding IDE",
    "longDescription": "HIDE: a local-first agentic coding IDE. Your whole project, always loaded, never billed, never truncated."
  }
}
